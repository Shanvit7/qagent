{
  "name": "@shanvit7/qagent",
  "version": "0.1.3",
  "description": "Behavioral regression testing for every Next.js staged change — AI probes your live app and generates focused Playwright tests that verify user flows didn't break",
  "type": "module",
  "bin": {
    "qagent": "dist/index.js"
  },
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "behavioral-testing",
    "regression-testing",
    "playwright",
    "react",
    "nextjs",
    "ai",
    "ollama",
    "qa",
    "qagent"
  ],
  "author": "Shanvit Shetty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shanvit7/qagent.git"
  },
  "homepage": "https://github.com/Shanvit7/qagent#readme",
  "bugs": {
    "url": "https://github.com/Shanvit7/qagent/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ollama": "^0.5.0",
    "simple-git": "^3.22.0",
    "ts-morph": "^21.0.0",
    "ink": "^4.4.1",
    "ink-box": "^2.0.0",
    "ink-select-input": "^5.0.0",
    "ink-text-input": "^5.0.0",
    "react": "^18.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.0.0",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
