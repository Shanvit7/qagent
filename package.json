{
  "name": "qagent",
  "version": "0.1.0",
  "description": "Behavioral regression tests for every staged change — AI probes your live app and generates focused e2e tests that verify user flows didn't break",
  "type": "module",
  "bin": {
    "qagent": "./dist/cli/index.js"
  },
  "module": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "bun run check && bun run build"
  },
  "keywords": [
    "behavioral-testing",
    "regression-testing",
    "e2e",
    "playwright",
    "react",
    "nextjs",
    "ai",
    "ollama",
    "qa",
    "qagent"
  ],
  "author": "Shanvit Shetty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shanvit7/qagent.git"
  },
  "homepage": "https://github.com/Shanvit7/qagent#readme",
  "bugs": {
    "url": "https://github.com/Shanvit7/qagent/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^12.0.0",
    "ollama": "^0.5.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.22.0",
    "ts-morph": "^21.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
